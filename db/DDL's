-- Table: public.document

-- DROP TABLE IF EXISTS public.document;

CREATE TABLE IF NOT EXISTS public.document
(
    document_id character varying(36) COLLATE pg_catalog."default" NOT NULL,
    encounter_id character varying(36) COLLATE pg_catalog."default" NOT NULL,
    document_type character varying(50) COLLATE pg_catalog."default" NOT NULL,
    document_date date NOT NULL,
    file_path character varying(255) COLLATE pg_catalog."default" NOT NULL,
    created_at timestamp without time zone DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT document_pkey PRIMARY KEY (document_id)
)

TABLESPACE pg_default;

ALTER TABLE IF EXISTS public.document
    OWNER to postgres;
-- Index: idx_doc_date

-- DROP INDEX IF EXISTS public.idx_doc_date;

CREATE INDEX IF NOT EXISTS idx_doc_date
    ON public.document USING btree
    (document_date ASC NULLS LAST)
    WITH (fillfactor=100, deduplicate_items=True)
    TABLESPACE pg_default;
-- Index: idx_encounter_doc

-- DROP INDEX IF EXISTS public.idx_encounter_doc;

CREATE INDEX IF NOT EXISTS idx_encounter_doc
    ON public.document USING btree
    (encounter_id COLLATE pg_catalog."default" ASC NULLS LAST)
    WITH (fillfactor=100, deduplicate_items=True)
    TABLESPACE pg_default;

Encounter Table:

CREATE TABLE encounter (
    encounter_id VARCHAR(36) PRIMARY KEY,
    mrn VARCHAR(20) NOT NULL,           -- match patient.mrn type
    practitioner_id VARCHAR(36) NOT NULL,
    encounter_type VARCHAR(50),
    start_date TIMESTAMP NOT NULL,
    end_date TIMESTAMP,
    status VARCHAR(20) DEFAULT 'active',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (mrn) REFERENCES patient_table(mrn) ON DELETE CASCADE
    -- FOREIGN KEY for practitioner can be added after practitioner table is created
);

-- Create indexes separately in PostgreSQL
CREATE INDEX idx_patient_date ON encounter (mrn, start_date);
