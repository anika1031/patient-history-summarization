-- Table: public.practitioner

-- DROP TABLE IF EXISTS public.practitioner;

CREATE TABLE IF NOT EXISTS public.practitioner
(
    practitioner_id integer NOT NULL DEFAULT nextval('practitioner_practitioner_id_seq'::regclass),
    first_name character varying(50) COLLATE pg_catalog."default" NOT NULL,
    last_name character varying(50) COLLATE pg_catalog."default" NOT NULL,
    department character varying(100) COLLATE pg_catalog."default",
    status character varying(20) COLLATE pg_catalog."default" DEFAULT 'Active'::character varying,
    created_at timestamp without time zone DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT practitioner_pkey PRIMARY KEY (practitioner_id)
)

TABLESPACE pg_default;

ALTER TABLE IF EXISTS public.practitioner
    OWNER to postgres;

